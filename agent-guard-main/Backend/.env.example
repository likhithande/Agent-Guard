# ----------------------------
# Generative Language API (Gemini Developer API)
# ----------------------------
# IMPORTANT: do NOT commit real keys. Set this in your shell or in Backend/.env
GOOGLE_API_KEY=REPLACE_ME

# ----------------------------
# Common GCP (required for Document AI, Storage, Firestore)
# ----------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us

# Authentication (recommended): Application Default Credentials
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ----------------------------
# Google Cloud Storage (optional but recommended)
# ----------------------------
GCS_BUCKET=your-gcs-bucket-name

# ----------------------------
# Document AI (required to extract text from PDFs/images in /documents/analyze)
# Create a processor in Document AI and paste its processor id here.
# ----------------------------
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=your-processor-id

# ----------------------------
# Document AI Warehouse (Content Warehouse) (optional)
# Requires a Warehouse instance + a document schema.
# ----------------------------
CONTENTWAREHOUSE_PROJECT_NUMBER=123456789012
CONTENTWAREHOUSE_LOCATION=us
CONTENTWAREHOUSE_DOCUMENT_SCHEMA_NAME=projects/123456789012/locations/us/documentSchemas/yourSchemaId

# ----------------------------
# Firestore (optional)
# ----------------------------
FIRESTORE_COLLECTION=audit_documents
